# ── Database ──────────────────────────────────────────────────────────────────
# Connection string used by Prisma and the application.
# For Docker Compose the hostname is the service name ("postgres").
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ticketing

# Individual values consumed by the postgres service in docker-compose.yml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ticketing

# ── Application ───────────────────────────────────────────────────────────────
# Port exposed by Docker to the host machine (default: 3000).
APP_PORT=4000

# Next.js environment
NODE_ENV=production
